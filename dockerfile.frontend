# dockerfile.frontend
FROM python:3.11-slim

WORKDIR /app

# Copy requirements
COPY frontend_requirements.txt .
RUN pip install --no-cache-dir -r frontend_requirements.txt

# Copy frontend code
COPY app/frontend.py ./
COPY model/ ./model/

EXPOSE 8501

CMD ["streamlit", "run", "frontend.py", "--server.port=8501", "--server.address=0.0.0.0"]
